{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": [
    "node_modules",
    "App.tsx",
    "main.tsx",
    "vite-env.d.ts",
    "bulk-upload.tsx",
    "certificate.tsx",
    "dashboard.tsx",
    "endorsement.tsx",
    "enrollment.tsx",
    "group-enrollment.tsx",
    "invoice.tsx",
    "invoice-reminders.tsx",
    "payment-recording.tsx",
    "termination.tsx",
    "provider.tsx",
    "index.tsx",
    "login.tsx",
    "group-enrollment.ts",
    "api-auth.ts",
    "auth-service.ts",
    "create-account.ts",
    "dependant.ts",
    "email-temples.ts",
    "endorsement-service.ts",
    "enrollment-service.ts",
    "generate-excel.ts",
    "generate-pdf.ts",
    "generate-schedule-excel.ts",
    "hero.ts",
    "identity-service.ts",
    "index.ts",
    "invoice-receipt-service.ts",
    "invoice-reminder-email.ts",
    "invoice-reminders-service.ts",
    "invoice-service.ts",
    "lists-service.ts",
    "payment-rec-service.ts",
    "plans-service.ts",
    "send-mail.ts",
    "send-payment-email.ts",
    "termination-service.ts",
    "endorsement-service.ts"
  ]
}
