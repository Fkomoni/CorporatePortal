generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  name          String
  role          String    @default("hr_admin")
  companyId     String?
  companyName   String?
  policyNumber  String?
  active        Boolean   @default(true)
  lastLogin     DateTime?
  mobile        String?
  twoFaEnabled  Boolean   @default(false)
  twoFaMethod   String    @default("email")
  // True once Prognosis has confirmed this exact password via
  // CorporateUserSignUp or ChangePassword. A local-only password reset
  // (forgot-password, where the old password is unknown so Prognosis's
  // ChangePassword can't be called) sets this back to false so the login
  // gate doesn't require a Prognosis check it knows is now out of sync.
  prognosisSynced Boolean @default(false)
  // Pending login/setup OTP (sha256 hash) — cleared once used
  loginOtpHash      String?
  loginOtpExpiresAt DateTime?
  loginOtpAttempts  Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions      Session[]
  accounts      Account[]

  @@map("users")
}

// NextAuth required tables
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model SchemeHealthSnapshot {
  id         String   @id @default(cuid())
  groupId    String
  yearMonth  String   // "YYYY-MM"
  score      Int
  lossRatio  Float?
  cor        Float?
  utilRate   Float?
  riskStatus String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([groupId, yearMonth])
  @@map("scheme_health_snapshots")
}

model MemberInvitation {
  id           String    @id @default(cuid())
  token        String    @unique @default(cuid())
  email        String
  employeeCode String
  schemeId     String
  schemeName   String
  groupId      String
  scope         String    @default("self") // "self" | "self-dependent" | "dependent-only"
  inviteType    String    @default("principal") // "principal" | "dependent"
  parentCif     String?   // CIF of principal — required for inviteType=dependent
  maxDependents Int       @default(1)
  usedCount     Int       @default(0)
  used          Boolean   @default(false)
  usedAt        DateTime?
  expiresAt     DateTime
  createdBy     String
  createdAt     DateTime  @default(now())

  @@index([email, employeeCode])
  @@map("member_invitations")
}

// Tracks which corporates have been sent the portal welcome email, and to
// which HR email — lets the sync cron detect new groups and HR email changes.
model CorporateSyncState {
  id                String    @id @default(cuid())
  groupId           String    @unique
  companyName       String?
  policyNumber      String?
  adminEmail        String?   // HR email the last welcome was sent to
  welcomeSentAt     DateTime? // null = baseline-seeded, never actually emailed
  lastSyncedAt      DateTime  @default(now())
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@map("corporate_sync_state")
}

// Per-company branding (logo stored as a data URL, capped at ~400 KB)
model CompanyBranding {
  id          String   @id @default(cuid())
  groupId     String   @unique
  logoDataUrl String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("company_branding")
}

// Future-dated terminations: TerminateMember has no date parameter, so a
// termination requested for a future date is held here and actually sent
// to Prognosis by the /api/cron/process-terminations job on that date.
model ScheduledTermination {
  id            String    @id @default(cuid())
  cifNumber     String
  memberName    String?
  groupId       String?
  effectiveDate DateTime  // date-only, stored at midnight UTC
  status        String    @default("pending") // pending | completed | failed | cancelled
  requestedBy   String    // HR user email
  requestedAt   DateTime  @default(now())
  processedAt   DateTime?
  error         String?

  @@index([status, effectiveDate])
  @@map("scheduled_terminations")
}

// Tracks members enrolled via an HR-issued self-service link (/enroll/[token]).
// Prognosis's ViewMembersPerGroup doesn't expose a reliable registration-source
// field, so we record it ourselves at submission time: any pending beneficiary
// whose CIF isn't in this table came in through the Enrolee mobile app instead.
model LinkRegistration {
  id        String   @id @default(cuid())
  cifNumber String   @unique
  groupId   String?
  createdAt DateTime @default(now())

  @@map("link_registrations")
}

model AuditLog {
  id          String   @id @default(cuid())
  timestamp   DateTime @default(now())
  userId      String?
  userEmail   String
  userName    String
  userRole    String
  loginType   String   // "hr" | "staff"
  companyId   String?
  companyName String?
  action      String
  resource    String
  details     Json?
  ipAddress   String?
  userAgent   String?

  @@index([companyId, timestamp])
  @@index([loginType, timestamp])
  @@map("audit_logs")
}
